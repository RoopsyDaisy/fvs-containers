# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
ENV/

# R renv library (like .venv for R)
renv/library/
renv/staging/
renv/local/

# Distribution / packaging
dist/
build/
*.egg-info/

# Jupyter
.ipynb_checkpoints/
*.ipynb_checkpoints

# IDE
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/mcp.json

# Data (customize as needed)
data/
*.csv
*.parquet
*.h5
*.hdf5
*.tif
*.tiff

# Logs and outputs
logs/
outputs/
*.log
wandb/

# Fortran unit files (from FVS)
fort.*

# FVS / fvsOL generated databases, spatial data, and runtime state
*.db
*.RData
projectId.txt
ProjectIsLocked.txt
projectIsLocked.txt

# Generated reports
MonteCarloReport_*.html

# Large report figures (regenerable from the notebooks; kept local, not in git)
docs/ReportImages/

# Locally built FVS binaries (compiled from vendor/fvs by the devcontainer)
.devcontainer/fvs-bin/

# OS
.DS_Store
Thumbs.db
